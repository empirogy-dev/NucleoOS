# Copia este archivo como  .env  y pega tus llaves de Supabase
# (Supabase → Project Settings → API)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key

# Llave de Gemini (gratis) para los resúmenes con IA de Aprendizaje.
# Consíguela en https://aistudio.google.com/apikey y pégala aquí.
VITE_GEMINI_API_KEY=tu-llave-de-gemini
